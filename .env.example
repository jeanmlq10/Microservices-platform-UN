# ═══════════════════════════════════════════════
# Variables de entorno - Plataforma Microservicios
# Copia este archivo como .env y ajusta los valores
# cp .env.example .env
# ═══════════════════════════════════════════════

# Puerto de Nginx (punto de entrada)
NGINX_PORT=80

# Backend
FLASK_DEBUG=false

# Puerto base para microservicios dinámicos (se incrementa: 9001, 9002, 9003...)
BASE_PORT=9001
